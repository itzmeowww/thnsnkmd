---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen w-screen bg-slate-900">
    <div
      class="relative max-w-3xl mx-auto w-full flex flex-col justify-center items-center px-10"
    >
      <slot />
    </div>
  </body>
</html>
