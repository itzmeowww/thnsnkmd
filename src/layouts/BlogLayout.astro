---
import type { MarkdownLayoutProps } from "astro";

type Props = MarkdownLayoutProps<{
  // Define frontmatter props here
  title: string;
  author: string;
  date: string;
}>;
const { frontmatter } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{frontmatter.title}</title>
  </head>
  <body class="min-h-screen w-screen bg-gray-900">
    <div
      class="text-white relative max-w-3xl mx-auto w-full flex flex-col justify-center items-center px-10 pt-12 overflow-x-hidden md:overflow-x-visible"
    >
      <h1 class="text-3xl font-medium">{frontmatter.title}</h1>
      <hr class="bg-gray-600 mt-2 mb-1 w-full" />
      <div class="text-gray-200 w-full flex justify-between items-center px-2">
        <p>{frontmatter.author}</p>
        <p>{frontmatter.date}</p>
      </div>
      <div class="prose prose-sm prose-invert py-4">
        <slot />
      </div>
    </div>
  </body>
</html>
